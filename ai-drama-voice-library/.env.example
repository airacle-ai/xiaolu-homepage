# 火山引擎 豆包 TTS 配置
# 复制此文件为 .env 然后填入真实 key
#
# ⚠️ 本项目使用的 S_xxx 音色是「音色复刻」生成的，必须用豆包原生 API。
#    所以 APP_ID 和 access_token 都是必填项。

# 豆包语音合成 · access_token（控制台「API 密钥管理」获取）
VOLC_TTS_API_KEY=your-access-token-here

# 豆包语音合成 · 应用 ID（控制台「应用管理」或「体验中心」获取）
# 路径：https://console.volcengine.com/speech/app
VOLC_TTS_APP_ID=your-app-id-here
